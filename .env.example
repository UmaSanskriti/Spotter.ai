# Copy to .env (local) or set these as Replit Secrets / Cloud Run env vars.

# Get a free key at https://aistudio.google.com/apikey
# The server accepts any of: GEMINI_API_KEY, API_KEY (AI Studio default), GOOGLE_API_KEY.
GEMINI_API_KEY=

# Optional overrides
# SPOTTER_MODEL=gemini-2.5-flash      # any Gemini model id; used by the agent + the filter
# SPOTTER_CARD_BUDGET_MS=90000        # hook pipeline: max ~1 card per this window
# PORT=8080
